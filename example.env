# Server Config
PORT=8080

# Supabase REST API Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-public-key

# Mercado Libre Configuration
ML_SITE_ID=MLM
ML_ACCESS_TOKEN=your_mercado_libre_access_token_if_any
ML_CLIENT_ID=your_client_id_if_using_oauth
ML_CLIENT_SECRET=your_client_secret_if_using_oauth

# Sync Bot Scheduler Config
SYNC_CRON=0 * * * *
SYNC_CATEGORY=materiales de construccion
